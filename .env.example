# Base de datos (Supabase / PostgreSQL)
# Copie este archivo a .env y complete DB_PASSWORD con la contraseña de Supabase.
DB_URL=jdbc:postgresql://aws-1-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
DB_USER=postgres.aegfjfdnpqxtqvnqvyok
DB_PASSWORD=

# Seguridad JWT (misma clave en todos los microservicios)
JWT_SECRET=

# Puertos locales
MS_USUARIOS_PORT=8080
MS_CONVOCATORIAS_PORT=8081
MS_POSTULACIONES_PORT=8082
API_GATEWAY_PORT=8083

# URLs internas entre microservicios
MS_USUARIOS_URL=http://localhost:8080
MS_CONVOCATORIAS_URL=http://localhost:8081
MS_POSTULACIONES_URL=http://localhost:8082

# CORS (origen del frontend Angular)
CORS_ORIGINS=http://localhost:4200

# Frontend Angular
API_URL=http://localhost:8083/api
